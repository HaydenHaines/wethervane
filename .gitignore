# Data directory (large files, not versioned)
data/raw/
data/assembled/
data/communities/
data/shifts/
data/polls/
data/covariance/
data/predictions/
data/validation/

# Keep directory structure
!data/*/.gitkeep

# Large visualization artifacts (regeneratable from pipeline)
data/viz/*.geojson

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# R
.Rhistory
.Rdata
.RData
.Ruserdata
renv/library/
renv/staging/
renv/local/

# Stan
*.hpp
*.o
*.exe
src/covariance/stan/community_covariance

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.playwright-mcp/
.idea/

# Brainstorming sessions
.superpowers/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# DuckDB runtime database (regeneratable via src/db/build_database.py)
data/*.duckdb

# Large model outputs
*.pkl
*.joblib
*.rds
*.stan.exe
